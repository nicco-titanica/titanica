# Titanica — apps/web environment. Copy to `.env` for local dev; never commit `.env`.
# In production these are set in Coolify, never in the repo (docs/02-ARCHITECTURE.md §8).

# Postgres. The local docker-compose (repo root) serves exactly this DSN.
DATABASE_URI=postgres://titanica:titanica@localhost:5432/titanica

# Payload secret — REQUIRED. Used to sign/encrypt. Generate a long random value:
#   openssl rand -base64 32
# Use a DIFFERENT, secret value in production.
PAYLOAD_SECRET=change-me-to-a-long-random-secret

# Public origin of the app.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
